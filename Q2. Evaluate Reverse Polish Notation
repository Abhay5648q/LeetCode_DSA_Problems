class Solution {
    public int evalRPN(String[] tokens) {
        Stack<String>st=new Stack<>();
        for(int i=0;i<tokens.length;i++){
              if (!tokens[i].equals("+") &&
                !tokens[i].equals("-") &&
                !tokens[i].equals("*") &&
                !tokens[i].equals("/")) {

                st.push(tokens[i]);
            }
            else if(tokens[i].equals("+")){
                String b=st.pop();
                String a=st.pop();
               int ans=Integer.parseInt(a)+Integer.parseInt(b);
                 st.push(Integer.toString(ans));
            }
             else if(tokens[i].equals("*")){
                String b=st.pop();
                String a=st.pop();
               int ans=Integer.parseInt(a)*Integer.parseInt(b);
                st.push(Integer.toString(ans));
            }
            else if(tokens[i].equals("-")){
                String b=st.pop();
                String a=st.pop();
               int ans=Integer.parseInt(a)-Integer.parseInt(b);
                 st.push(Integer.toString(ans));
            }
              else if(tokens[i].equals("/")){
                String b=st.pop();
                String a=st.pop();
               int ans=Integer.parseInt(a)/Integer.parseInt(b);
                 st.push(Integer.toString(ans));
            }
        }
         return Integer.parseInt(st.pop());
    }
}

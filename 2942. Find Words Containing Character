class Solution {
    public List<Integer> findWordsContaining(String[] words, char x) {
        List<Integer>ans=new ArrayList<>();
        for(int i=0;i<words.length;i++){
            String str=words[i];
            int idx=0;
            while(idx<str.length()){
                if(str.charAt(idx)==x){
                    ans.add(i);
                    break;
                }
                idx++;
            }
        }
        return ans;
    }
}

class Solution {
    public ListNode deleteMiddle(ListNode head) {
        ListNode temp=head;
        int count=0;
        while(temp!=null){
            temp=temp.next;
            count++;
        }
        int idx=count/2;
        ListNode curr=head;
        ListNode prev=null;
        int dest=0;
        while(dest<idx&&curr!=null&&curr.next!=null){
            prev=curr;
            curr=curr.next;
            dest++;
        }
       if(head.next==null){
        return null;
       }
        prev.next=curr.next;
        return head;
    }
}

class Solution {
    public char processStr(String s, long k) {
        if (s.length() == 0) {
            return '.';
        }
        long len = 0;
        int n = s.length();

        for (int i = 0; i < n; i++) {
            char ch = s.charAt(i);
            if (ch != '#' && ch != '%' && ch != '*') {
                len++;
            } else if (ch == '#') {
                len *= 2;
            } else if (ch == '*') {
                if (len > 0)
                    len--;
            }
        }
        for (int i = n - 1; i >= 0; i--) {
            char ch = s.charAt(i);
            if (ch == '#') {
                len /= 2;
                if (k >= len) {
                    k = k - len;
                }
            } else if (ch == '*') {
                len++;
                if (k >= len - 1) {
                    k++; 
                }
            } else if (ch == '%') {
                k = len - k - 1;
            } else {
                len--;
                if (len == k) {
                    return ch;
                }

            }

        }
        return '.';
    }
}

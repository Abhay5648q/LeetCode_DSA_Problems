class Solution {
    public int[] arrayRankTransform(int[] arr) {
        HashMap<Integer,Integer>map=new HashMap<>();
       int sorte[]= Arrays.stream(arr).distinct().sorted().toArray();
        for( int i=0;i<sorte.length;i++){
            map.put(sorte[i],i+1);
        }
        for(int i=0;i<arr.length;i++){
            arr[i]=map.get(arr[i]);
        }
        return arr;
    }
}

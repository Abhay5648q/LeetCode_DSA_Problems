class Solution {
    public int maxAbsoluteSum(int[] nums) {
        int maxSum=nums[0];
        int minSum=nums[0];
        int res=Math.abs(nums[0]);
        for(int i=1;i<nums.length;i++){
            int v1=nums[i];
           int v2= minSum+nums[i];
            int v3=maxSum+nums[i];
            minSum=Math.min(v1,Math.min(v3,v2));
            maxSum=Math.max(v1,Math.max(v2,v3));
            res = Math.max(res, Math.max(Math.abs(minSum), Math.abs(maxSum)));
        }
    
        return res;
    }
}

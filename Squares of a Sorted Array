class Solution {
    public int[] sortedSquares(int[] nums) {
       int low=0;
       int high=nums.length-1;
       int arr[]=new int[nums.length];
       for(int i=nums.length-1;i>=0;i--){
        if(Math.abs(nums[low])<Math.abs(nums[high])){
            arr[i]=nums[high]*nums[high];
            high--;
        }
        else {
            arr[i]=nums[low]*nums[low];
            low++;
        }
       }
    return arr;
    }
}

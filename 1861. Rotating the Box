class Solution {
    public char[][] rotateTheBox(char[][] boxGrid) {

        int m = boxGrid.length;
        int n = boxGrid[0].length;
        char rotateBox[][] = new char[n][m];

        for (int i = 0; i < n; i++) {
            for (int j = 0; j < m; j++) {
                rotateBox[i][j] = boxGrid[j][i];
            }
        }

        for (int i = 0; i < n; i++) {
            int left = 0, right = m - 1;
            while (left < right) {
                char temp = rotateBox[i][left];
                rotateBox[i][left] = rotateBox[i][right];
                rotateBox[i][right] = temp;
                left++;
                right--;
            }
        }

        for (int j = 0; j < m; j++) {
            for (int i = n - 1; i >= 0; i--) {
                if (rotateBox[i][j] == '.') {
                    int stoneidx = -1;
                    for (int k = i - 1; k >= 0; k--) {
                        if (rotateBox[k][j] == '*') {
                            break;
                        }
                        else if (rotateBox[k][j] == '#') {
                            stoneidx = k;
                            break;
                        }
                    }
                    if (stoneidx != -1) {

                        rotateBox[i][j] = '#';
                        rotateBox[stoneidx][j] = '.';
                    }
                }
            }
        }

        return rotateBox;
    }
}

class Solution {
    public int maxSubarraySumCircular(int[] nums) {
        int max = nums[0];
        int currentMax = 0;
        int min = nums[0];
        int currentMin = 0;
        int totalSum = 0;
        
        for(int x:nums){
            currentMax = Math.max(x,currentMax+x);
            max = Math.max(max,currentMax);

            currentMin = Math.min(x,currentMin+x);
            min = Math.min(min,currentMin);

            totalSum += x;
        }

        if(max<0){
            return max;
        }
        return Math.max(max,totalSum-min);
    }
}
